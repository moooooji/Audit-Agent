{
  "actors": [
    {
      "id": 1,
      "name": "External User",
      "type": "External User",
      "capabilities": [
        "Check $BERA Airdrop",
        "Claim $BERA Airdrop",
        "Connect to Berachain",
        "Provide liquidity to protocols",
        "Stake receipt tokens in Reward Vaults",
        "Delegate $BGT to validators",
        "Vote on governance proposals",
        "Create governance proposals",
