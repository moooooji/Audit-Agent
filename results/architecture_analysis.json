        "Boost a Validator with $BGT",
        "Claim Incentives",
        "Swap assets",
        "Mint $HONEY",
        "Redeem $HONEY",
        "Trade assets on BEX",
        "Trade assets on Honey Swap",
        "Bridge tokens from Ethereum to Berachain"
      ]
    },
    {
      "id": 2,
      "name": "Validator",
      "type": "Internal Service",
      "description": "A blockchain node being run to validate transactions, produce blocks and come to consensus with other validators in the network",
      "capabilities": [
        "Stake $BERA",
        "Propose blocks",
        "Direct $BGT rewards to Reward Vaults",
        "Collect Incentives from Reward Vaults",
        "Set Incentive Commission",
        "Change commission percentage"
      ]
    },
    {
      "id": 3,
      "name": "Protocol",
